generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model InfluencerSession {
  id           String   @id @default(cuid())
  name         String
  brandName    String
  brandUrl     String
  brandSocials String   @default("[]")
  platforms    String
  influencer   String
  campaignGoal String
  contentStyle String
  mainMessage  String
  notes        String?
  status       String   @default("pending")
  result       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("influencer_sessions")
}
